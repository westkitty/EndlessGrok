{
  "name": "endlessgrok",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dock": "bash scripts/install-macos-app.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "assets:validate": "tsx scripts/validate-asset-manifest.ts",
    "assets:preview": "tsx scripts/preview-asset-manifest.ts",
    "assets:ledger:validate": "tsx scripts/validate-assets-ledger.ts",
    "starsilk:validate": "tsx scripts/validate-starsilk-ledger.ts",
    "starsilk:fixtures": "tsx scripts/generate-starsilk-fixtures.ts",
    "events:materialize": "tsx scripts/materialize-event-json.ts",
    "assets:generate:batch1": "tsx scripts/generate-starsilk-svg-batch.ts",
    "assets:generate:batch2": "tsx scripts/generate-starsilk-svg-batch2.ts",
    "assets:promote:batch1": "tsx scripts/promote-generated-batch.ts",
    "assets:promote:status": "tsx scripts/promote-asset-status.ts"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
